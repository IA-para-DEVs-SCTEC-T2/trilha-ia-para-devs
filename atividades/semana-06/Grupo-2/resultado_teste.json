    {
      "name": "Pedidos - Sucesso",
      "item": [
        {
          "name": "POST /pedidos - Pedido válido sem cupom",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Pedido criado', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Pedido contém campos obrigatórios', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('cliente');",
                  "    pm.expect(json).to.have.property('produto');",
                  "    pm.expect(json).to.have.property('quantidade');",
                  "    pm.expect(json).to.have.property('subtotal');",
                  "    pm.expect(json).to.have.property('desconto');",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('status');",
                  "});",
                  "",
                  "pm.test('Cliente correto no pedido', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.cliente).to.eql('João Silva');",
                  "});",
                  "",
                  "pm.test('Subtotal calculado corretamente (3500 * 2 = 7000)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.subtotal).to.eql(7000);",
                  "});",
                  "",
                  "pm.test('Sem cupom: desconto deve ser 0', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.desconto).to.eql(0);",
                  "});",
                  "",
                  "pm.test('Total igual ao subtotal quando sem desconto', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.total).to.eql(json.subtotal);",
                  "});",
                  "",
                  "pm.test('Status do pedido é criado', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('criado');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
