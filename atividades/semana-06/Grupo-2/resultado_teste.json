      "item": [
        {
          "name": "GET / - Verifica API funcionando",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Mensagem de boas-vindas presente', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.message).to.eql('API de pedidos funcionando');",
                  "});",
                  "",
                  "pm.test('Endpoints listados na resposta', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.endpoints).to.have.property('produtos');",
                  "    pm.expect(json.endpoints).to.have.property('pedido');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
