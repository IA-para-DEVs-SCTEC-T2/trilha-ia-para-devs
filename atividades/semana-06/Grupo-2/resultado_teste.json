        {
          "name": "POST /pedidos - Pedido com cupom DESCONTO10",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Pedido criado', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Desconto de 10% aplicado corretamente', function () {",
                  "    var json = pm.response.json();",
                  "    var subtotal = json.subtotal;",
                  "    var descontoEsperado = subtotal * 0.10;",
                  "    pm.expect(json.desconto).to.eql(descontoEsperado);",
                  "});",
                  "",
                  "pm.test('Total = subtotal - desconto', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.total).to.eql(json.subtotal - json.desconto);",
                  "});",
                  "",
                  "pm.test('Subtotal correto (80 * 4 = 320)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.subtotal).to.eql(320);",
                  "});",
                  "",
                  "pm.test('Total correto com 10% de desconto (320 - 32 = 288)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.total).to.eql(288);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
