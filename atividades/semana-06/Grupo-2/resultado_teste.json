    {
      "name": "Produtos",
      "item": [
        {
          "name": "GET /produtos - Lista todos os produtos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Retorna array de produtos', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "    pm.expect(json.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Produtos possuem campos obrigatórios', function () {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function (produto) {",
                  "        pm.expect(produto).to.have.property('id');",
                  "        pm.expect(produto).to.have.property('nome');",
                  "        pm.expect(produto).to.have.property('preco');",
                  "        pm.expect(produto).to.have.property('estoque');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Contém 3 produtos cadastrados', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.length).to.eql(3);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/produtos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "produtos"
              ]
            }
          },
          "response": []
        }
      ]
